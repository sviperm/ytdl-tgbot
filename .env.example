# Telegram API Credentials (get from https://my.telegram.org)
TG_APP_ID=
TG_API_HASH=

# Telegram Bot Token (get from https://t.me/BotFather)
TG_BOT_API=

# Whitelist (comma separated user IDs, e.g. 12345678,87654321)
# Leave empty to allow everyone
WHITE_LIST_IDS=""

# PO Token provider URL (bgutil). Docker Compose sets this automatically.
POT_PROVIDER_URL="http://127.0.0.1:4416"

# --- Instagram (all OPTIONAL; sensible defaults are baked into the code) ---
# Public "fixer" service used to fetch video when this server's IP is blocked by
# Instagram. Override only if the service rebrands / goes down.
#IG_FIXER_URL="https://www.instagram7.com"
#IG_OFFLOAD_BASE="https://oginstagram.com/offload"

# Proxy for Instagram requests. If set, the bot fetches directly from Instagram
# (GraphQL/api, original quality) through this proxy instead of the fixer service.
# Format: http://user:pass@host:port
#IG_PROXY_URL=""

# Instagram GraphQL doc_ids (only used with IG_PROXY_URL). Override if IG changes them.
#IG_MOBILE_DOC_ID="8845758582119845"
#IG_WEB_DOC_ID="25531498899829322"
